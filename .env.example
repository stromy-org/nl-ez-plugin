# Environment variables consumed by nl-gov-data-plugin.
#
# Every ${VAR} referenced in .agents/mcp.json must appear here so the
# plugin-completeness validator passes (Inv #4) and downstream clients
# know which secrets to set. Copy to .env (never commit .env) and fill in.
# nl-gov-data MCP needs no env var — URL is hardcoded (public ACA endpoint,
# per-user OAuth) — listed here as a reminder.

# ms365 MCP (local stdio server) — token cache location + account selection
MS365_TOKEN_CACHE=
MS365_SELECTED_ACCOUNT=
